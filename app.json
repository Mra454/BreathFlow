{
  "expo": {
    "name": "BreathFlow",
    "slug": "BreathFlow",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "breathflow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.mra454.BreathFlow"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0e14"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
